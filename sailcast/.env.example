# Location (DCA / Washington DC default)
# LOCATION_LAT=38.8512
# LOCATION_LON=-77.0402
# LOCATION_NAME=DCA / Washington DC

# NOAA tide station (8594900 = Washington, Potomac River DC)
# NOAA_TIDE_STATION=8594900

# NWS marine zone (ANZ535 = Tidal Potomac from Key Bridge to Indian Head)
# MARINE_ZONE_ID=ANZ535

# Optional: User-Agent for NWS API requests
# NWS_USER_AGENT=SailCast/1.0 (your-club)

# OpenAI: copy this to .env and set OPENAI_API_KEY (never commit .env or real keys).
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-5-nano

# Boat type for recommendation: scot | cruiser | both (default). Scot = stricter limits; Cruiser = more tolerant.
# BOAT_TYPE=both

# Optional: disable report cache (useful in dev). Set ENV=dev or DISABLE_REPORT_CACHE=1
# ENV=dev
# DISABLE_REPORT_CACHE=1
