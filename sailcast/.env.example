# SailCast – copy to .env and set OPENAI_API_KEY. Never commit .env or real keys.

# --- OpenAI (required for AI recommendations) ---
OPENAI_API_KEY=your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Location (defaults: DCA / Washington DC) ---
# LOCATION_LAT=38.8512
# LOCATION_LON=-77.0402
# LOCATION_NAME=DCA / Washington DC

# --- NOAA tide station (8594900 = Washington, Potomac River DC) ---
# NOAA_TIDE_STATION=8594900

# --- NWS marine zone (ANZ535 = Tidal Potomac Key Bridge to Indian Head) ---
# MARINE_ZONE_ID=ANZ535

# --- Optional: password wall (HTTP Basic Auth) ---
# Set both to require a username/password before viewing the site (e.g. on Lightsail).
# BASIC_AUTH_USER=bitnami
# BASIC_AUTH_PASSWORD=your-secret-password

# --- Optional ---
# NWS_USER_AGENT=SailCast/1.0 (your-club)
# BOAT_TYPE=both
# ENV=dev
# DISABLE_REPORT_CACHE=1
