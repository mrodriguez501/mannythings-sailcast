# ========================
# SailCast Server Environment Variables
# ========================
# Create .env only if you don't have one (never overwrite existing .env):
#   cp -n .env.example .env
# Then edit .env and add your OPENAI_API_KEY etc.

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-5-nano

# NWS Configuration
NWS_OFFICE=LWX
NWS_GRIDPOINT_X=97
NWS_GRIDPOINT_Y=74
NWS_USER_AGENT=SailCast/1.0 (your-email@example.com)

# Marine and tides (optional; Potomac / DCA defaults)
# MARINE_ZONE_ID=ANZ535
# NOAA_TIDE_STATION=8594900

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Environment (development | production)
ENVIRONMENT=development

# Budget Limits (protects against runaway API costs)
OPENAI_MONTHLY_BUDGET=5.00
OPENAI_DAILY_BUDGET=0.50
OPENAI_MAX_REQUESTS_PER_HOUR=5
